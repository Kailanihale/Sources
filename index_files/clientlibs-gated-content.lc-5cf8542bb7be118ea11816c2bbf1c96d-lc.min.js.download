ALLOWED_DOMAINS = [
    "thomsonreuters.com",
    "thomsonreuters.com.ar",
    "thomsonreuters.com.au",
    "thomsonreuters.com.br",
    "thomsonreuters.ca",
    "thomsonreuters.cl",
    "thomsonreuters.cn",
    "thomsonreuters.com.hk",
    "thomsonreuters.in",
    "thomsonreuters.co.jp",
    "thomsonreuters.co.kr",
    "thomsonreuters.tw",
    "thomsonreuters.co.uk",
    "thomsonreuters.com.my",
    "thomsonreutersmexico.com",
    "thomsonreuters.co.nz",
    "thomsonreuters.com.pe",
    "thomsonreuters.com.sg",
    "sweetandmaxwell.co.uk"
];
(function (document, $) {
    "use strict";

    const isGated = document.body.getAttribute("data-is-gated");
    const gatedFormName = document.body.getAttribute("data-gated-form");

    if (isGated && !isFormSubmitted(gatedFormName)) {
        const url = new URL(
            window.location.origin
            + window.location.pathname.replace(".html", "")
            + ".gated.json"
        );
        fetch(url).then(response => {
            if (response.status === 200) {
                response.json().then(data => {
                    if (data.location && isValidRedirect(data.location)) {
                        window.location = mergeQueryParams(data.location);
                    }
                });
            }
        });
    }

    function isFormSubmitted(formName) {
        const formCookieName = " tr_ewp_submitted_forms=";
        const cookie = document.cookie.split(";").find(item => item.startsWith(formCookieName));
        if (cookie) {
            try {
                const formsJson = JSON.parse(decodeURIComponent(cookie.replace(formCookieName, "")));
                if (formsJson && formsJson.forms) {
                    return formsJson.forms.includes(formName);
                }
            } catch (e) {
                console.error(e);
                return false;
            }
        }
    }

    //This function validates redirect url to prevent open redirect attacks
    function isValidRedirect(url) {
        try {
            const parsedUrl = new URL(url);
            return ALLOWED_DOMAINS.some(domain => parsedUrl.hostname.endsWith(domain));
        } catch (e) {
            console.error("Invalid URL:", url);
            return false;
        }
    }

    function mergeQueryParams(destinationUrl) {
        const currentParams = new URLSearchParams(window.location.search);
        const targetUrl = new URL(destinationUrl);
        const targetParam = new URLSearchParams(targetUrl.search);

        currentParams.forEach((value, key) => {
            if (key !== "gatedContent") targetParam.set(key, value);
        });
        targetUrl.search = targetParam.toString();
        return targetUrl;
    }

})(document, $);

document.addEventListener("DOMContentLoaded", function () {
  const root = document.querySelector(".root");
  const containers = root?.querySelectorAll(".container");
  // IMPORTANT: force single DOM Element
  let breadcrumb = document.querySelector(".tr-Breadcrumb-items");
  if (!(breadcrumb instanceof Node) || !containers || containers.length < 2) {
    console.warn("Breadcrumb is not a DOM node or containers missing");
    return;
  }
  const secondContainer = containers[1];
  secondContainer.parentNode.insertBefore(
    breadcrumb,
    secondContainer.nextSibling
  );
});
